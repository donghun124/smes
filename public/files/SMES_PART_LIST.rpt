        row 
        {
            name = "SPART";
            height = 1;
            visibility = TRUE;
            usecolumns = FALSE;
            rule = "if (GetValue(\"MAIN_PART\") == 1) then\r\n  StepOver()\r\nelse\r\n\r\n  if (GetValue(\"PART_PREFIX\")== \"DUMMY\") then\r\n\r\n    StepOver()\r\n\r\n  else\r\n\r\n  if (GetValue(\"PART_PROFILE\")== \"PL*\") then\r\n\r\n    StepOver()\r\n\r\n  else\r\n\r\n    Output()\r\n\r\n  endif\r\n\r\n  endif\r\n\r\nendif";
            contenttype = "PART";
            sorttype = COMBINE;

            valuefield 
            {
                name = "field_PROFILE";
                location = (77, 0);
                formula = "if(match(GetValue(\"PROFILE\"),\"PL*\"))then\r\nmid(GetValue(\"PROFILE\"),\"0\",find(GetValue(\"PROFILE\"),\"*\"))\r\nelse\r\nGetValue(\"PROFILE\")\r\nendif \r\n";
                maxnumoflines = 1;
                datatype = STRING;
                class = "";
                cacheable = TRUE;
                formatzeroasempty = FALSE;
