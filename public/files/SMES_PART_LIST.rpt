            valuefield 
            {
                name = "PART_NN";
                location = (130, 0);
                formula = "if GetValue(\"NAME\") == \"LADDER(POST)\" then GetValue(\"NUMBER\") *GetFieldFormula(\"LRQ\") else GetValue(\"NUMBER\") endif";
